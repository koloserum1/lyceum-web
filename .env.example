# -----------------------------------------------------------------------------
# Sanity — projekt „lyceum“ (Project ID: iw5edpoc, dataset: production)
# -----------------------------------------------------------------------------
# Lokálne: skopíruj tento súbor ako `.env.local` a doplníš token nižšie.
# Na Verceli: Project Settings → Environment Variables (rovnaké názvy).
# -----------------------------------------------------------------------------

# Verejné — používajú sa v prehliadači / pri fetchi (môžeš nechať default).
NEXT_PUBLIC_SANITY_PROJECT_ID=iw5edpoc
NEXT_PUBLIC_SANITY_DATASET=production

# Tajné — len na serveri (API routes). Nevkladaj do verejného repa s hodnotou.
# Vytvor: https://www.sanity.io/manage → projekt lyceum → API → Tokens
# Práva: Editor alebo Administrator (musí vedieť vytvárať dokumenty typu dodLead).
#
SANITY_API_WRITE_TOKEN=
